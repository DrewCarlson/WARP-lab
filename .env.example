# Cloudflare credentials
CF_API_TOKEN=your-api-token-here
CF_ACCOUNT_ID=your-account-id-here

# Domain
WARPLAB_DOMAIN=your.homelab
WARPLAB_SSH_SUBDOMAIN=ssh

# Tunnel tokens (from Cloudflare Zero Trust dashboard)
CF_PUBLIC_TUNNEL_TOKEN=your-public-tunnel-token
CF_WARP_TUNNEL_TOKEN=your-warp-tunnel-token

# Tunnel IDs (from Cloudflare Zero Trust dashboard)
CF_PUBLIC_TUNNEL_ID=your-public-tunnel-id
CF_WARP_TUNNEL_ID=your-warp-tunnel-id
